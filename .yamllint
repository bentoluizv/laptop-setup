---
extends: default

ignore: |
  .ansible_facts/
  collections/

rules:
  line-length:
    max: 120
    allow-non-breakable-words: true
  truthy:
    allowed-values: ["true", "false"]
    check-keys: false
  comments-indentation: disable
  comments:
    min-spaces-from-content: 1
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
